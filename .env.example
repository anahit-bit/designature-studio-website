# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Google Drive OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Custom Search Engine ID (for Shop This Look feature)
GOOGLE_CSE_ID=
GOOGLE_API_KEY=

# Replicate API Token
REPLICATE_API_TOKEN=

# Cloudinary (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

#Serper API Key
SERPER_API_KEY=

# Vite dev HMR WebSocket (npm run dev). Set if 24778 is taken.
# VITE_HMR_PORT=24888

# Free-tier users tracking sheet (Google Sheets)
# Defaults to the hardcoded spreadsheet ID in `server.ts` if not set.
FREE_USERS_SPREADSHEET_ID=

# Service account credentials (provide ONE of the following)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
# Optional alternative to GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON (path to a JSON file)
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEYFILE=
